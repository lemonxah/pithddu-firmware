# Generic ESP32-S3 (8 MB flash + Quad PSRAM): the broadest-compatible profile.
# Quad PSRAM works on more S3 variants than Octal; switch to CONFIG_SPIRAM_MODE_OCT
# if your module has Octal PSRAM (the R8 parts) for full bandwidth.
CONFIG_SPIRAM_MODE_QUAD=y
CONFIG_SPIRAM_SPEED_80M=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y
CONFIG_ESPTOOLPY_FLASHSIZE="8MB"
