# pithddu — ESP32-S3 SimHub dashboard (Seeed XIAO S3), VID 303a / PID 4002.
# Lets the pith-dashboard app open the HID command channel (report id 2) and
# flash firmware over HID without root, and lets esptool reflash in ROM mode.
#
# Install:
#   sudo cp tools/99-pithddu.rules /etc/udev/rules.d/99-pithddu.rules
#   sudo udevadm control --reload-rules
#   sudo udevadm trigger --action=add --subsystem-match=hidraw --subsystem-match=tty --subsystem-match=usb
#   (or just re-plug the device)
#
# TAG+="uaccess" grants the logged-in desktop user an ACL (systemd-logind, the
# Arch/CachyOS way). MODE="0666" is a hard fallback so it works regardless of
# session/seat — it only opens up this one device node.

# --- HID command channel: the app talks + uploads firmware over this ---
SUBSYSTEM=="hidraw", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="4002", MODE="0666", TAG+="uaccess"

# --- CDC serial node + raw USB device (running firmware 303a:4002) ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="4002", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="usb", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="4002", MODE="0660", TAG+="uaccess"

# --- ROM download/bootloader mode (303a:1001) for esptool reflash ---
SUBSYSTEM=="tty", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", MODE="0660", TAG+="uaccess"
SUBSYSTEM=="usb", ATTRS{idVendor}=="303a", ATTRS{idProduct}=="1001", MODE="0660", TAG+="uaccess"
